log:
  level: INFO
timeouts:
  read: 5s
  write: 10s
  idle: 120s
  shutdown: 15s
server:
  host: 0.0.0.0
  port: 8080
projectID: {{ project_id }}
registry:
  baseURL: {{ registry_url }}
  timeout: 10s
keyManagerCacheTTL:
  privateKeysSeconds: 300
  publicKeysSeconds: 3600
redisAddr: {{ redis_instance_ip }}:6379
regID: {{ registry.subscriber_id }}
regKeyID: {{ registry.key_id }}
event:
  projectID: {{ project_id }}
  topicID: {{ onix_topic_name }}
{% if security.enable_inbound_auth %}
auth:
  allowedAudience: {{ domains.subscriber }}/api
  allowedIssuers:
    - https://accounts.google.com
    - accounts.google.com
    - https://iam.googleapis.com/projects/{{ project_number }}/locations/global/workloadIdentityPools/onix-{{ suffix }}-pool
  allowedSAs:
    - subscriber-invoker-sa-{{ suffix }}@{{ project_id }}.iam.gserviceaccount.com
{% endif %}